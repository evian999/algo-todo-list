# 生产环境务必设置强随机字符串（用于 JWT 签名）
AUTH_SECRET=

# 推荐：Supabase Postgres（关系表 + replace_user_app_data 函数）。Dashboard → Settings → API 复制 URL 与 service_role
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# 可选：未配置 Supabase 时用 Upstash Redis（整包 JSON）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# 可选：无用户数据时写入首个账户（用户名与口令请自行设定，勿提交真实值）
# DEFAULT_AUTH_USERNAME=
# DEFAULT_AUTH_PASSWORD=
